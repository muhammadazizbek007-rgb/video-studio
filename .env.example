# Firebase Web App config
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_WEB_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_WEB_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_DATABASE_ID="(default)"

# Comma-separated emails allowed to access Video Studio (leave empty = allow all)
VITE_VIDEO_STUDIO_ALLOWED_EMAILS=""

# Cloudflare Worker API URL (set after deploying workers/)
VITE_WORKER_URL="https://video-studio-api.YOUR-SUBDOMAIN.workers.dev"
