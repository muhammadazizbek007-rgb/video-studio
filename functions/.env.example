# ─── Firebase Admin ───────────────────────────────────────────────────────────
# Service account JSON (for non-GCP environments)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GPMARKET_STORAGE_BUCKET=your-project-id.firebasestorage.app

# ─── Video Studio Providers ───────────────────────────────────────────────────

# Seedance 2.0
SEEDANCE_API_KEY=your_seedance_api_key
SEEDANCE_API_BASE_URL=https://seedance2.app

# Replicate (Wan, Kling, Luma)
REPLICATE_API_TOKEN=

# WaveSpeed (Wan fast)
WAVESPEED_API_KEY=

# HuggingFace Inference API (CogVideoX, LTX, SVD, Open-Sora)
HUGGINGFACE_API_TOKEN=

# Leonardo AI (Motion)
LEONARDO_API_KEY=

# JSON2Video
JSON2VIDEO_API_KEY=

# Anthropic Claude API (for MCP video analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Access control ───────────────────────────────────────────────────────────
# Comma-separated emails (leave empty = allow all authenticated users)
VIDEO_STUDIO_ALLOWED_EMAILS=
